# Copier en .env (hors git) et renseigner. Aucun secret n'est commité ni dans l'image.
# Clés attendues — cf. docs/ENVIRONMENT.md.

# --- Admin (compte unique, comparé à temps constant, non hashé) ---
ADMIN_USER=admin
ADMIN_PASS=change-me

# --- MCP : secret validé par TOUS les tools (deploy_token en argument) ---
DEPLOY_TOKEN=change-me-long-random

# --- Cookie de déverrouillage client : clé HMAC de signature ---
UNLOCK_COOKIE_SECRET=change-me-32-bytes-min-random

# --- Runtime ---
# Chemin du volume monté dans le conteneur (cf. docker-compose.yml).
DATABASE_URL=sqlite:///data/latch.sqlite?mode=rwc
PORT=5150

# --- Déploiement ---
# Version d'image GHCR à déployer. Défaut `latest` (= dernière release).
# En prod, pinner une version (ex. 1.2.3 ou sha-abc1234) pour un déploiement
# reproductible et un rollback trivial. Schéma de tags : cf. docs/ENVIRONMENT.md.
LATCH_IMAGE_TAG=latest
