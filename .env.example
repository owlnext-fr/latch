# Copier en .env (hors git) et renseigner. Aucun secret n'est commité ni dans l'image.
# Clés attendues — cf. docs/ENVIRONMENT.md.

# --- Admin (compte unique, comparé à temps constant, non hashé) ---
ADMIN_USER=admin
ADMIN_PASS=change-me

# --- MCP : secret validé par TOUS les tools (deploy_token en argument) ---
# REQUIS en prod (le boot refuse de démarrer si absent — fail-secure).
DEPLOY_TOKEN=change-me-long-random

# --- URL publique (distribution) : source de vérité de l'hôte public ---
# Sert à MCP (URL renvoyée par deploy_prototype) et à allowed_hosts (rmcp >= 1.4).
# REQUIS en prod (le boot refuse de démarrer si absent). En dev : http://localhost:<PORT>.
LATCH_PUBLIC_BASE_URL=https://latch.owlnext.fr

# --- Cookie de déverrouillage client : clé HMAC de signature (≥ 64 octets, comme SESSION_SECRET) ---
# Key::from() exige ≥ 64 bytes : le boot REFUSE de démarrer en prod si absent (fail-secure).
# En dev, un fallback déterministe est utilisé. Générer avec : openssl rand -hex 32
UNLOCK_COOKIE_SECRET=change-me-64-bytes-min-random-0123456789abcdef0123456789abcdef
# Durée de vie du cookie unlock (jours). Défaut 30.
LATCH_UNLOCK_TTL_DAYS=30
# Rate-limit /unlock (governor in-memory, compteurs perdus au reboot). Défauts :
LATCH_UNLOCK_RL_IP_BURST=5
LATCH_UNLOCK_RL_IP_REPLENISH_PER_SEC=1
LATCH_UNLOCK_RL_SLUG_BURST=20
LATCH_UNLOCK_RL_SLUG_PERIOD_SECS=3
# Rate-limit /api/login (governor in-memory, compteurs perdus au reboot). Défauts :
LATCH_LOGIN_RL_BURST=5
LATCH_LOGIN_RL_PER_SECOND=2
# Rate-limit écriture des commentaires /c/<slug>/comments (governor in-memory). Défauts :
LATCH_COMMENT_RL_IP_BURST=10
LATCH_COMMENT_RL_IP_PER_SECOND=1
LATCH_COMMENT_RL_SLUG_BURST=60
LATCH_COMMENT_RL_SLUG_PERIOD_SECS=1

# --- Session admin ---
# Clé HMAC de signature du cookie de session admin (≥ 64 octets aléatoires — même contrainte que
# UNLOCK_COOKIE_SECRET : Key::from() exige ≥ 64 bytes, sinon panique au démarrage). REQUIS en prod
# (le boot refuse de démarrer si absent hors Dev/Test — fail-secure). Générer avec : openssl rand -hex 32
SESSION_SECRET=

# --- Stockage versions ---
# Racine de stockage des HTML de versions. DOIT être un chemin ABSOLU pointant sur
# le volume monté (cf. docker-compose.yml `./data:/data` et DATABASE_URL ci-dessous) :
# le WORKDIR de l'image est /app, donc une valeur RELATIVE (`./data`, `data`) résout
# vers /app/data — la couche ÉPHÉMÈRE du conteneur, effacée à chaque recréation
# (docker compose up -d). La base SQLite (chemin absolu) survivrait, mais les HTML
# seraient perdus → 404/500 sur les versions au prochain redéploiement. Voir docs/QUIRKS.md.
# Prod (image): /data. Dev (cargo loco start depuis backend/) : ./data.
LATCH_STORAGE_ROOT=/data

# --- SPA React (interface admin) ---
# Racine des assets buildés de la SPA. DOIT être un chemin ABSOLU en prod (comme
# LATCH_STORAGE_ROOT) : le boot REFUSE de démarrer si relatif ou absent hors Dev/Test
# (fail-secure — évite de servir depuis la couche éphémère /app). L'image Docker la
# pose à /app/frontend/dist. Dev (cargo loco start depuis backend/) : ../frontend/dist.
# Déploiement hors image (build backend nu + dist copié à la main) : NE PAS laisser
# cette valeur VIDE en prod — vide → défaut relatif → boot refusé. Poser explicitement
# un chemin absolu vers le dist déployé (ex. /opt/latch/frontend/dist).
LATCH_SPA_DIST=

# --- Runtime ---
# Chemin du volume monté dans le conteneur (cf. docker-compose.yml).
DATABASE_URL=sqlite:///data/latch.sqlite?mode=rwc
PORT=5150
# Taille max du body des requêtes (le deploy envoie le HTML mono-fichier en JSON).
# Ex. "5mb" (défaut), "10mb", "32mb", ou "disable" pour aucune limite.
LATCH_BODY_LIMIT=5mb

# --- Déploiement ---
# Version d'image GHCR à déployer. Défaut `latest` (= dernière release).
# En prod, pinner une version (ex. 1.2.3 ou sha-abc1234) pour un déploiement
# reproductible et un rollback trivial. Schéma de tags : cf. docs/ENVIRONMENT.md.
LATCH_IMAGE_TAG=latest

# --- Validation de forme (tailles max, octets) ---
# Taille max du HTML déployé (octets). Défaut 5 Mo.
# LATCH_MAX_HTML_BYTES=5242880
# Taille max du descripteur d'ancrage d'un commentaire (octets). Défaut 8 Ko.
# LATCH_MAX_ANCHOR_BYTES=8192
