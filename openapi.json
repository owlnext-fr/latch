{
  "openapi": "3.1.0",
  "info": {
    "title": "latch admin API",
    "description": "API JSON de l'admin latch (session cookie same-origin).",
    "license": {
      "name": "MIT OR Apache-2.0",
      "identifier": "MIT OR Apache-2.0"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "POST /api/login — vérifie ADMIN_USER/ADMIN_PASS à temps constant, pose la session.",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Authentifié (cookie de session posé)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "401": {
            "description": "Identifiants invalides"
          }
        }
      }
    },
    "/api/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "POST /api/logout — invalide la session côté serveur (supprime la ligne en DB).",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "Session détruite",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "403": {
            "description": "Origin invalide (CSRF)"
          }
        }
      }
    },
    "/api/projects": {
      "get": {
        "tags": [
          "projects"
        ],
        "summary": "GET /api/projects — liste tous les projets (sans PIN, invariant §9.2).",
        "operationId": "list",
        "responses": {
          "200": {
            "description": "Liste des projets (sans PIN)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProjectListItem"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Non authentifié"
          }
        }
      },
      "post": {
        "tags": [
          "projects"
        ],
        "summary": "POST /api/projects — crée un nouveau projet.",
        "operationId": "create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProjectReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Projet créé",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectDetail"
                }
              }
            }
          },
          "400": {
            "description": "Requête invalide"
          },
          "401": {
            "description": "Non authentifié"
          },
          "403": {
            "description": "Origin invalide (CSRF)"
          }
        }
      }
    },
    "/api/projects/{id}": {
      "get": {
        "tags": [
          "projects"
        ],
        "summary": "GET /api/projects/{id} — détail d'un projet avec ses versions et son PIN.",
        "operationId": "detail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Identifiant du projet",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Détail du projet (avec PIN)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectDetail"
                }
              }
            }
          },
          "401": {
            "description": "Non authentifié"
          },
          "404": {
            "description": "Projet inconnu"
          }
        }
      },
      "put": {
        "tags": [
          "projects"
        ],
        "summary": "PUT /api/projects/{id} — met à jour le nom ou le brand_name d'un projet.",
        "operationId": "update",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Identifiant du projet",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProjectReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Projet mis à jour",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectDetail"
                }
              }
            }
          },
          "400": {
            "description": "Requête invalide"
          },
          "401": {
            "description": "Non authentifié"
          },
          "403": {
            "description": "Origin invalide (CSRF)"
          },
          "404": {
            "description": "Projet inconnu"
          }
        }
      },
      "delete": {
        "tags": [
          "projects"
        ],
        "summary": "DELETE /api/projects/{id} — supprime un projet et ses versions.",
        "operationId": "delete",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Identifiant du projet",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Projet supprimé",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "401": {
            "description": "Non authentifié"
          },
          "403": {
            "description": "Origin invalide (CSRF)"
          },
          "404": {
            "description": "Projet inconnu"
          }
        }
      }
    },
